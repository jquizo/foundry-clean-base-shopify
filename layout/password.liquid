<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }} &mdash; Coming Soon</title>

    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- unless settings.type_body_font.system? and settings.type_header_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    {{ content_for_header }}

    <style>
      :root {
        --font-heading: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-body:    {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-body-style:    {{ settings.type_body_font.style }};
        --font-body-weight:   {{ settings.type_body_font.weight }};
        --font-heading-style: {{ settings.type_header_font.style }};
        --font-heading-weight: {{ settings.type_header_font.weight }};
        --font-size-scale: {{ settings.body_base_size | divided_by: 16.0 }};
        --heading-scale:   {{ settings.heading_base_size | divided_by: 100.0 }};

        --color-primary:       {{ settings.color_primary }};
        --color-primary-hover: {{ settings.color_primary_hover }};
        --color-text:          {{ settings.color_text }};
        --color-text-subtle:   {{ settings.color_text_subtle }};
        --color-bg:            {{ settings.color_bg }};
        --color-bg-subtle:     {{ settings.color_bg_subtle }};
        --color-border:        {{ settings.color_border }};

        --radius-btn:         {{ settings.button_radius }};
        --layout-content-max: {{ settings.layout_content_max }}px;
      }

      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
    </style>

    {{ 'tokens.css' | asset_url | stylesheet_tag }}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    <style>
      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: var(--font-body);
        font-style: var(--font-body-style);
        font-weight: var(--font-body-weight);
        background-color: var(--color-bg-subtle);
        color: var(--color-text);
      }

      .password-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: var(--space-4);
      }

      .password-card {
        background: var(--color-bg);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        padding: var(--space-10) var(--space-8);
        width: 100%;
        max-width: 440px;
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
      }

      .password-card__name {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
        letter-spacing: var(--tracking-wider);
        text-transform: uppercase;
        color: var(--color-text-muted);
        margin: 0;
      }

      .password-card__heading {
        font-family: var(--font-heading);
        font-size: var(--text-3xl);
        font-weight: var(--font-weight-bold);
        line-height: var(--leading-tight);
        color: var(--color-text);
        margin: 0;
      }

      .password-card__message {
        font-size: var(--text-base);
        color: var(--color-text-subtle);
        line-height: var(--leading-relaxed);
        margin: 0;
      }

      .password-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
      }

      .password-form__error {
        font-size: var(--text-sm);
        color: var(--color-error);
        margin: 0;
      }

      .password-form__input {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        font-family: var(--font-body);
        font-size: var(--text-base);
        color: var(--color-text);
        background: var(--color-bg);
        border: var(--border);
        border-radius: var(--radius-btn);
        outline: 2px solid transparent;
        outline-offset: 2px;
        transition: border-color var(--duration-fast) var(--ease-out),
                    outline-color var(--duration-fast) var(--ease-out);
      }

      .password-form__input:focus {
        border-color: var(--color-primary);
        outline-color: var(--color-primary);
      }

      .password-form__submit {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        font-family: var(--font-body);
        font-size: var(--text-base);
        font-weight: var(--font-weight-semibold);
        color: var(--color-primary-text);
        background: var(--color-primary);
        border: none;
        border-radius: var(--radius-btn);
        cursor: pointer;
        transition: background-color var(--duration-fast) var(--ease-out);
      }

      .password-form__submit:hover {
        background: var(--color-primary-hover);
      }

      .password-footer {
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        text-align: center;
      }

      .password-footer a {
        color: var(--color-text-muted);
      }

      @media (max-width: 480px) {
        .password-page {
          padding: 0;
          align-items: flex-start;
        }

        .password-card {
          border-radius: 0;
          box-shadow: none;
          min-height: 100vh;
        }
      }
    </style>

    <script>
      document.documentElement.classList.replace('no-js', 'js');
    </script>
  </head>

  <body>
    <div class="password-page">
      <div class="password-card">

        <p class="password-card__name">{{ shop.name }}</p>

        <h1 class="password-card__heading">Coming Soon</h1>

        <p class="password-card__message">
          {%- if shop.description != blank -%}
            {{ shop.description }}
          {%- else -%}
            We&rsquo;re putting the finishing touches on something special.
          {%- endif -%}
        </p>

        {%- form 'storefront_password' -%}
          <div class="password-form">
            {%- if form.errors -%}
              <p class="password-form__error">{{ 'general.password_page.login_form_error' | t }}</p>
            {%- endif -%}

            <label class="visually-hidden" for="password">
              {{ 'general.password_page.password_label' | t }}
            </label>

            <input
              class="password-form__input"
              type="password"
              id="password"
              name="password"
              autocomplete="current-password"
            >

            <button type="submit" class="password-form__submit">
              {{ 'general.password_page.login_form_submit' | t }}
            </button>
          </div>
        {%- endform -%}

        <div class="password-footer">
          {{ powered_by_shopify }}
        </div>

      </div>
    </div>

    <div hidden>{{ content_for_layout }}</div>
  </body>
</html>
