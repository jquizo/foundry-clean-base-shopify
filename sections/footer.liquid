{%- comment -%} sections/footer.liquid {%- endcomment -%}

<footer class="footer" data-section-id="{{ section.id }}">
  <div class="container">

    {%- comment -%} Footer top — logo + nav columns {%- endcomment -%}
    <div class="footer__top">

      {%- comment -%} Brand column {%- endcomment -%}
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__logo-link" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            {{
              section.settings.logo
              | image_url: width: 200
              | image_tag:
                class: 'footer__logo-image',
                alt: section.settings.logo.alt | default: shop.name,
                width: section.settings.logo.width,
                height: section.settings.logo.height,
                loading: 'lazy'
            }}
          {%- else -%}
            <span class="footer__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>

        {%- if section.settings.tagline != blank -%}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- comment -%} Social links {%- endcomment -%}
        {%- liquid
          assign social_accounts = 'instagram,facebook,tiktok,pinterest,youtube,twitter'
          assign has_social = false
          for account in social_accounts
            assign setting_key = 'social_' | append: account
            if section.settings[setting_key] != blank
              assign has_social = true
            endif
          endfor
        -%}

        {%- if has_social -%}
          <ul class="footer__social-list" role="list" aria-label="Social media links">
            {%- if section.settings.social_instagram != blank -%}
              <li>
                <a href="{{ section.settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_facebook != blank -%}
              <li>
                <a href="{{ section.settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_tiktok != blank -%}
              <li>
                <a href="{{ section.settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_pinterest != blank -%}
              <li>
                <a href="{{ section.settings.social_pinterest }}" class="footer__social-link" aria-label="Pinterest" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2a10 10 0 0 0-3.6 19.3c0-.8.1-2 .4-2.9l2-8.5s-.5-1-.5-2.5c0-2.3 1.4-4 3-4 1.4 0 2.1 1 2.1 2.3 0 1.4-.9 3.5-1.3 5.4-.4 1.6.8 2.9 2.2 2.9 2.6 0 4.4-3.3 4.4-7.3 0-3-2-5.2-5.1-5.2a5.6 5.6 0 0 0-5.8 5.6c0 1.1.4 2.3 1 2.9a.4.4 0 0 1 .1.4l-.4 1.5c-.1.4-.3.5-.7.3-2-1-3.3-3.8-3.3-6.1 0-5 3.6-9.5 10.3-9.5 5.4 0 9.6 3.9 9.6 9 0 5.4-3.4 9.8-8.1 9.8-1.6 0-3-.8-3.5-1.8l-1 3.7c-.4 1.4-1.3 3.1-1.9 4.2A10 10 0 0 0 22 12 10 10 0 0 0 12 2z"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_youtube != blank -%}
              <li>
                <a href="{{ section.settings.social_youtube }}" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </a>
              </li>
            {%- endif -%}
            {%- if section.settings.social_twitter != blank -%}
              <li>
                <a href="{{ section.settings.social_twitter }}" class="footer__social-link" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M4 4l16 16M4 20L20 4"/></svg>
                </a>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} Nav columns {%- endcomment -%}
      {%- for i in (1..3) -%}
        {%- liquid
          assign menu_key = 'menu_' | append: i
          assign heading_key = 'menu_' | append: i | append: '_heading'
        -%}
        {%- if section.settings[menu_key] != blank -%}
          <div class="footer__nav-column">
            {%- if section.settings[heading_key] != blank -%}
              <p class="footer__nav-heading">{{ section.settings[heading_key] }}</p>
            {%- endif -%}
            <ul class="footer__nav-list" role="list">
              {%- for link in linklists[section.settings[menu_key]].links -%}
                <li>
                  <a href="{{ link.url }}" class="footer__nav-link">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- comment -%} Footer bottom — copyright + payment icons {%- endcomment -%}
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        {%- if section.settings.copyright_text != blank -%}
          &nbsp;&mdash;&nbsp;{{ section.settings.copyright_text }}
        {%- endif -%}
      </p>

      {%- if section.settings.show_payment_icons and shop.enabled_payment_types != empty -%}
        <ul class="footer__payment-list" role="list" aria-label="Accepted payment methods">
          {%- for type in shop.enabled_payment_types -%}
            <li>
              {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

  </div>
</footer>

{% style %}
  .footer {
    background: var(--color-bg-subtle);
    border-top: var(--border);
    padding-block: var(--section-padding-block);
  }

  /* --- Top grid --- */

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 600px) {
    .footer__top {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .footer__top {
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
  }

  /* --- Brand column --- */

  .footer__logo-link {
    display: inline-block;
    margin-bottom: var(--space-4);
  }

  .footer__logo-image {
    max-height: 2rem;
    width: auto;
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    line-height: var(--leading-relaxed);
    max-width: 28ch;
    margin-bottom: var(--space-6);
  }

  /* --- Social --- */

  .footer__social-list {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-text-subtle);
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out);
  }

  .footer__social-link:hover {
    color: var(--color-text);
    background: var(--color-bg-muted);
  }

  /* --- Nav columns --- */

  .footer__nav-heading {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer__nav-link:hover {
    color: var(--color-text);
  }

  /* --- Bottom bar --- */

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: var(--border);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    max-width: none;
  }

  /* --- Payment icons --- */

  .footer__payment-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .footer__payment-icon {
    height: 1.5rem;
    width: auto;
    border-radius: var(--radius-sm);
  }
{% endstyle %}

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "placeholder": "A short description of your store"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "Column 1 heading"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Column 1 menu"
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "Column 2 heading"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Column 2 menu"
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "Column 3 heading"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Column 3 menu"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "X (Twitter) URL"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Additional copyright text",
      "placeholder": "All rights reserved"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "default": true,
      "label": "Show payment icons"
    }
  ]
}
{% endschema %}