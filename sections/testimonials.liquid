{%- comment -%} sections/testimonials.liquid {%- endcomment -%}

<section class="testimonials" data-section-id="{{ section.id }}">
  <div class="container">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="testi__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="testi__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="testi__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testi__grid">
      {%- for block in section.blocks -%}
        <div class="testi__card" {{ block.shopify_attributes }}>

          <p class="testi__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}★{%- else -%}☆{%- endif -%}
            {%- endfor -%}
          </p>

          {%- if block.settings.review != blank -%}
            <div class="rte testi__review">{{ block.settings.review }}</div>
          {%- endif -%}

          {%- if block.settings.author != blank -%}
            <p class="testi__author">{{ block.settings.author }}</p>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% style %}
  .testimonials {
    padding-block: var(--section-padding-block);
    background-color: var(--color-bg-subtle);
  }

  .testi__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .testi__heading {
    font-size: var(--text-3xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
  }

  .testi__subheading {
    font-size: var(--text-lg);
    color: var(--color-text-subtle);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-4);
    max-width: 56ch;
    margin-inline: auto;
  }

  .testi__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--grid-gap);
  }

  .testi__card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .testi__stars {
    color: var(--color-primary);
    font-size: var(--text-lg);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .testi__review {
    flex: 1;
  }

  .testi__author {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    margin: auto 0 0;
  }
{% endstyle %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What our customers say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "placeholder": "A short line supporting your heading"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "richtext",
          "id": "review",
          "label": "Review",
          "default": "<p>Share what a customer said about your product or service. A genuine review builds trust with potential buyers.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Happy Customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
