{%- comment -%} sections/slideshow.liquid {%- endcomment -%}

<section
  class="slideshow"
  data-section-id="{{ section.id }}"
  style="--slide-min-height: {{ section.settings.min_height }}vh;"
>

  <div class="slideshow__track">
    {%- for block in section.blocks -%}
      <div
        class="slideshow__slide{% if forloop.first %} active{% endif %}"
        style="--slide-text-color: {{ block.settings.text_color }}; --overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
        {{ block.shopify_attributes }}
      >

        {%- if block.settings.image != blank -%}
          {%- assign slide_load_val     = 'lazy' -%}
          {%- assign slide_priority_val = 'auto' -%}
          {%- if forloop.first -%}
            {%- assign slide_load_val     = 'eager' -%}
            {%- assign slide_priority_val = 'high' -%}
          {%- endif -%}
          <div class="slideshow__media" aria-hidden="true">
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                alt: '',
                loading: slide_load_val,
                fetchpriority: slide_priority_val,
                sizes: '100vw'
            }}
          </div>
        {%- endif -%}

        {%- if block.settings.show_overlay -%}
          <div class="slideshow__overlay"></div>
        {%- endif -%}

        <div class="container slideshow__content">
          {%- if block.settings.heading != blank -%}
            <h2 class="slideshow__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}

          {%- if block.settings.subheading != blank -%}
            <p class="slideshow__subheading">{{ block.settings.subheading }}</p>
          {%- endif -%}

          {%- if block.settings.btn_label != blank and block.settings.btn_url != blank -%}
            <a href="{{ block.settings.btn_url }}" class="slideshow__btn">
              {{ block.settings.btn_label }}
            </a>
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button type="button" class="slideshow__prev" aria-label="{{ 'sections.slideshow.previous_slide' | t }}">&#8249;</button>
    <button type="button" class="slideshow__next" aria-label="{{ 'sections.slideshow.next_slide' | t }}">&#8250;</button>

    <div class="slideshow__dots" role="list">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="slideshow__dot{% if forloop.first %} active{% endif %}"
          role="listitem"
          aria-label="{{ 'sections.slideshow.go_to_slide' | t: index: forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

<script>
  (function () {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const slides = section.querySelectorAll('.slideshow__slide');
    const dots   = section.querySelectorAll('.slideshow__dot');
    let current  = 0;

    function goTo(n) {
      slides[current].classList.remove('active');
      if (dots[current]) {
        dots[current].classList.remove('active');
        dots[current].setAttribute('aria-selected', 'false');
      }
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      if (dots[current]) {
        dots[current].classList.add('active');
        dots[current].setAttribute('aria-selected', 'true');
      }
    }

    const prev = section.querySelector('.slideshow__prev');
    const next = section.querySelector('.slideshow__next');
    if (prev) prev.addEventListener('click', function () { goTo(current - 1); });
    if (next) next.addEventListener('click', function () { goTo(current + 1); });
    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () { goTo(i); });
    });
  })();
</script>

{% style %}
  .slideshow {
    position: relative;
    min-height: var(--slide-min-height, 60vh);
    overflow: hidden;
    background: var(--color-black);
  }

  /* --- Track --- */

  .slideshow__track {
    position: relative;
    width: 100%;
    min-height: inherit;
  }

  /* --- Slides --- */

  .slideshow__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-slow) var(--ease-in-out);
  }

  .slideshow__slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* --- Media --- */

  .slideshow__media {
    position: absolute;
    inset: 0;
  }

  .slideshow__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* --- Overlay --- */

  .slideshow__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / var(--overlay-opacity, 0.4));
  }

  /* --- Content --- */

  .slideshow__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-4);
    min-height: var(--slide-min-height, 60vh);
    padding-block: var(--section-padding-block);
  }

  .slideshow__heading {
    font-size: var(--text-4xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--slide-text-color, #ffffff);
    max-width: 18ch;
    margin: 0;
  }

  .slideshow__subheading {
    font-size: var(--text-lg);
    color: var(--slide-text-color, #ffffff);
    opacity: 0.85;
    line-height: var(--leading-relaxed);
    max-width: 44ch;
    margin: 0;
  }

  .slideshow__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--slide-text-color, #ffffff);
    border: 2px solid var(--slide-text-color, #ffffff);
    border-radius: var(--radius-btn);
    background: transparent;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
    margin-top: var(--space-2);
  }

  .slideshow__btn:hover {
    background: var(--slide-text-color, #ffffff);
    color: var(--color-black);
  }

  /* --- Prev / Next --- */

  .slideshow__prev,
  .slideshow__next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(0 0 0 / 0.3);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-full);
    font-size: var(--text-xl);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .slideshow__prev { left: var(--space-4); }
  .slideshow__next { right: var(--space-4); }

  .slideshow__prev:hover,
  .slideshow__next:hover {
    background: rgb(0 0 0 / 0.6);
  }

  /* --- Dots --- */

  .slideshow__dots {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: var(--space-2);
    z-index: 3;
  }

  .slideshow__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border-radius: var(--radius-full);
    border: 2px solid var(--color-white);
    background: transparent;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .slideshow__dot.active {
    background: var(--color-white);
  }

  /* --- Responsive --- */

  @media (max-width: 767px) {
    .slideshow__heading {
      font-size: var(--text-3xl);
    }

    .slideshow__subheading {
      font-size: var(--text-base);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section-slideshow",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "min_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Minimum height",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "placeholder": "Slide heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "placeholder": "A short supporting line"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button label",
          "placeholder": "Shop now"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Overlay"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show dark overlay",
          "default": true
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 90,
          "step": 5,
          "unit": "%",
          "label": "Overlay opacity",
          "default": 40
        },
        {
          "type": "header",
          "content": "Colours"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text colour",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
